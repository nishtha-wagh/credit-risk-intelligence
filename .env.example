# =============================================================
# LLM PROVIDER — pick one block, comment out the others
# =============================================================

# --- OPTION 1: Groq (recommended — free, fast, no GPU needed) ---
# Sign up at console.groq.com → API Keys → Create key
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=gsk_your_groq_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# --- OPTION 2: Ollama (fully local, no API key, needs GPU/8GB RAM) ---
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434

# --- OPTION 3: OpenAI (paid) ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=

# =============================================================
# EMBEDDINGS — pick one block
# =============================================================

# --- OPTION 1: Ollama embeddings (free, recommended) ---
# Run first: ollama pull nomic-embed-text
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# --- OPTION 2: OpenAI embeddings (paid, ~$0.01 per run) ---
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# =============================================================
# VECTOR STORE
# =============================================================
FAISS_INDEX_PATH=data/processed/index.faiss
METADATA_PATH=data/processed/metadata.json

# =============================================================
# API SETTINGS
# =============================================================
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# =============================================================
# RETRIEVAL SETTINGS
# =============================================================
TOP_K_RESULTS=5
MIN_SIMILARITY_SCORE=0.70
